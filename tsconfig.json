{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@tsrlib/configs": ["../tsrlib/packages/configs/src/index.ts"],
      "@tsrlib/database": ["../tsrlib/packages/database/src/index.ts"],
      "@tsrlib/loggers": ["../tsrlib/packages/loggers/src/index.ts"],
      "@tsrlib/markets": ["../tsrlib/packages/markets/src/index.ts"],
      "@tsrlib/utils": ["../tsrlib/packages/utils/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*", "scripts/**/*", "tests/**/*"]
}
